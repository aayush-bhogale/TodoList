
@model List<ToDoList.Models.ToDoItem>
<div class="row">
	<div class="col-md-12">
		<h2>ToDo List</h2>
		@if (Model != null && Model.Any())
		{
			<table class="table table-striped">
				<thead>
					<tr>
						<th>Title</th>
						<th>Description</th>
						<th>Status</th>
						<th>Actions</th>
					</tr>
				</thead>
				<tbody>
					@foreach(var todo in Model)
					{
						<tr>
							<td>@todo.Title</td>
							<td>@todo.Description</td>
							<td>@(todo.IsCompleted ? "Completed" : "Pending")</td>
							<td>
								<a asp-action="Edit" asp-route-id="@todo.Id" class="btn btn-warning">Edit</a>
								<a asp-action="Delete" asp-route-id="@todo.Id" class="btn btn-danger">Delete</a>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}
		else
		{
			<p>No todo items found. Add a new one!</p>
		}
		<a asp-controller="Todo" asp-action="Create" class="btn btn-primary">
			Create Todo
		</a>

	</div>
</div>
